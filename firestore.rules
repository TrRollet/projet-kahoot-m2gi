rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(quizData) {
      return isAuth() && quizData.ownerId == request.auth.uid;
    }
    
    function isEditor(quizData) {
      return isAuth() && request.auth.uid in quizData.get('editors', []);
    }
    
    function isReader(quizData) {
      return isAuth() && request.auth.uid in quizData.get('readers', []);
    }
    
    function canRead(quizData) {
      return isOwner(quizData) || isEditor(quizData) || isReader(quizData);
    }
    
    function canEdit(quizData) {
      return isOwner(quizData) || isEditor(quizData);
    }
    
    // users: lecture publique (vérif unicité username), écriture par propriétaire
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isAuth() && request.auth.uid == userId &&
        request.resource.data.username.size() >= 3 &&
        request.resource.data.username.size() <= 20;
      allow delete: if false;
    }
    
    // games: lecture publique (rejoindre via code), écriture par host ou joueurs
    match /games/{gameId} {
      allow get: if true;
      allow list: if isAuth();
      allow create: if isAuth() && request.resource.data.hostId == request.auth.uid;
      allow delete: if isAuth() && resource.data.hostId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.hostId == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerIds']) &&
         (request.auth.uid in request.resource.data.playerIds ||
          request.auth.uid in resource.data.playerIds))
      );

      // players: lecture par tous, écriture par propriétaire ou host
      match /players/{playerId} {
        allow read: if isAuth();
        allow create, update: if isAuth() && request.auth.uid == playerId;
        allow delete: if isAuth() && (
          request.auth.uid == playerId ||
          get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.auth.uid
        );
      }
    }

    // quizzes: lecture par owner/editor/reader, écriture par owner/editor
    match /quizzes/{quizId} {
      allow read: if canRead(resource.data);
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.title.size() <= 50 &&
        request.resource.data.get('description', '').size() <= 150;
      allow update: if (canEdit(resource.data) &&
        request.resource.data.title.size() <= 50 &&
        request.resource.data.get('description', '').size() <= 150
      ) || (
        isAuth() && (
          (request.auth.uid in resource.data.get('editors', []) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['editors']) &&
           !(request.auth.uid in request.resource.data.get('editors', []))) ||
          (request.auth.uid in resource.data.get('readers', []) &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readers']) &&
           !(request.auth.uid in request.resource.data.get('readers', [])))
        )
      );
      allow delete: if isOwner(resource.data);

      // questions: héritent des permissions du quiz parent
      match /questions/{questionId} {
        allow read: if canRead(get(/databases/$(database)/documents/quizzes/$(quizId)).data);
        allow create, update: if canEdit(get(/databases/$(database)/documents/quizzes/$(quizId)).data) &&
          request.resource.data.get('text', '').size() <= 120;
        allow delete: if canEdit(get(/databases/$(database)/documents/quizzes/$(quizId)).data);
      }
    }
  }
}
